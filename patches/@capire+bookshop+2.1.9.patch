# The @hcql annotation causes a SyntaxError in CDS 8 due to an incompatible path-to-regexp
# version used internally. Removing it keeps the services accessible via OData and REST only.
# The cat-service.js fixes work around a CDS 8 issue where cds.entities() returns undefined
# at init() time; using the fully-qualified entity name string avoids the problem.
diff --git a/node_modules/@capire/bookshop/srv/admin-service.cds b/node_modules/@capire/bookshop/srv/admin-service.cds
index 883fd1a..ed6c513 100644
--- a/node_modules/@capire/bookshop/srv/admin-service.cds
+++ b/node_modules/@capire/bookshop/srv/admin-service.cds
@@ -6,5 +6,5 @@ service AdminService @(odata:'/admin') {
   entity Genres as projection on my.Genres;
 }
 
-// Additionally serve via HCQL and REST
-annotate AdminService with @hcql @rest;
+// Additionally serve via REST
+annotate AdminService with @rest;
diff --git a/node_modules/@capire/bookshop/srv/cat-service.cds b/node_modules/@capire/bookshop/srv/cat-service.cds
index b9da4b6..5c4e8fc 100644
--- a/node_modules/@capire/bookshop/srv/cat-service.cds
+++ b/node_modules/@capire/bookshop/srv/cat-service.cds
@@ -19,5 +19,5 @@ service CatalogService @(odata:'/browse') {
   action submitOrder ( book: Books:ID, quantity: Integer );
 }
 
-// Additionally serve via HCQL and REST
-annotate CatalogService with @hcql @rest;
+// Additionally serve via REST
+annotate CatalogService with @rest;
diff --git a/node_modules/@capire/bookshop/srv/cat-service.js b/node_modules/@capire/bookshop/srv/cat-service.js
index 1598f05..0d25a98 100644
--- a/node_modules/@capire/bookshop/srv/cat-service.js
+++ b/node_modules/@capire/bookshop/srv/cat-service.js
@@ -2,7 +2,6 @@ const cds = require('@sap/cds')
 
 class CatalogService extends cds.ApplicationService { init() {
 
-  const { Books } = cds.entities ('sap.capire.bookshop')
   const { ListOfBooks } = this.entities
 
   // Add some discount for overstocked books
@@ -14,11 +13,11 @@ class CatalogService extends cds.ApplicationService { init() {
   this.on ('submitOrder', async req => {
     let { book:id, quantity } = req.data
     if (quantity < 1) return req.error (400, `quantity has to be 1 or more`)
-    let succeeded = await UPDATE (Books,id) 
+    let succeeded = await UPDATE ('sap.capire.bookshop.Books',id) 
       .with `stock = stock - ${quantity}` 
       .where `stock >= ${quantity}` 
     if (succeeded) return
-    else if (!this.exists(Books,id)) req.error (404, `Book #${id} doesn't exist`)
+    else if (!await this.exists('sap.capire.bookshop.Books',id)) req.error (404, `Book #${id} doesn't exist`)
     else req.error (409, `${quantity} exceeds stock for book #${id}`)
   })
 
