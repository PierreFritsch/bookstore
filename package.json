{
  "name": "@capire/bookstore",
  "version": "2.0.1",
  "description": "Shows how to reuse and compose with CAP.",
  "repository": "https://github.com/capire/bookstore",
  "dependencies": {
    "@capire/bookshop": "*",
    "@capire/common": "*",
    "@capire/data-viewer": "*",
    "@capire/orders": "*",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "8.9.8",
    "@sap/cds-dk": "8.9.15",
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "@cap-js/cds-test": "*",
    "@cap-js/sqlite": "^1.11.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "chest": "chest",
    "jest": "jest",
    "test": "chest",
    "postinstall": "patch-package"
  },
  "overrides": {
    "@sap/cds": "8.9.8",
    "@sap/cds-compiler": "5.9.8"
  },
  "cds": {
    "requires": {
      "ReviewsService": "odata",
      "OrdersService": "odata",
      "messaging": true,
      "db": {
        "[development]": {
          "model": "db/sqlite"
        },
        "[production]": {
          "model": "db/hana"
        }
      },
      "html5-repo": true
    },
    "fiori": {
      "preview": {
        "ui5": {
          "version": "1.130.9"
        }
      }
    },
    "log": {
      "service": true
    }
  }
}
